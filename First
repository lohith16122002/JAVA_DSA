1.//Maximum Subarray using Kadane's Algorithm

class Solution {
    public int maxSubArray(int[] nums) {
        int maxSum=nums[0];
        int current=nums[0];
        for(int i=1;i<nums.length;i++){
            current=Math.max(nums[i],current+nums[i]);
            maxSum=Math.max(maxSum,current);
        }
        return maxSum;
    }
}

2.Maximum product of subarray using Kadane's Algorithm
class Solution {
    public int maxProduct(int[] nums) {
        int maxs=nums[0];
        for(int i=0;i<nums.length;i++){
            int product=1;
            for(int j=i;j<nums.length;j++){
                product*=nums[j];
                maxs=Math.max(maxs,product);
            }
            
        }return maxs;
    }
}
