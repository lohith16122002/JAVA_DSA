Plus One problem that used carry propogation in cpus,big integer arthematic ,calculator app etc
class Solution {
    public int[] plusOne(int[] digits) {
        int n=digits.length;
        for(int i=n-1;i>=0;i--){
            if(digits[i]<9){digits[i]++; return digits;}  digits[i]=0;
        }
       
     
        int[] res=new int[digits.length+1];
        res[0]=1;
        return res;
    }
}

MISSING NUMBER IN ARRAY
class Solution {
    public int missingNumber(int[] nums) {
        long n=nums.length;
        long sum=n*(n+1)/2;
        long ArrayS=0;
        for(int ele:nums){
            ArrayS+=ele;
        }
        return (int)(sum-ArrayS);
    }
}
